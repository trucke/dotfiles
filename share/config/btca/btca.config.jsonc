{
  "$schema": "https://btca.dev/btca.schema.json",
  "providerTimeoutMs": 300000,
  "resources": [
    {
      "type": "git",
      "name": "svelte-docs",
      "url": "https://github.com/sveltejs/svelte.dev",
      "branch": "main",
      "searchPath": "apps/svelte.dev"
    },
    {
      "type": "git",
      "name": "tailwindcss",
      "url": "https://github.com/tailwindlabs/tailwindcss.com",
      "branch": "main",
      "searchPath": "src/docs",
      "specialNotes": "This is the tailwindcss docs website repo, not the actual tailwindcss repo. Use the docs to answer questions about tailwindcss."
    },
    {
      "type": "git",
      "name": "go",
      "url": "https://github.com/golang/go",
      "branch": "master"
    },
    {
      "type": "git",
      "name": "netbird-docs",
      "url": "https://github.com/netbirdio/docs",
      "branch": "main",
      "searchPath": "src/pages"
    },
    {
      "type": "git",
      "name": "linkwarden-docs",
      "url": "https://github.com/linkwarden/docs",
      "branch": "main"
    }
  ],
  "model": "gpt-5.4-mini",
  "provider": "opencode"
}