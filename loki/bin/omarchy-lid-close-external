#!/usr/bin/env bash

set -euo pipefail

# Leave normal undocked lid handling to logind.
omarchy-hw-external-monitors || exit 0

# Prevent a delayed lid-open action from racing this monitor transition.
lock="${XDG_RUNTIME_DIR:-/tmp}/omarchy-lid-display.lock"
exec 9>"${lock}"
flock -w 10 9 || exit 1

monitors="$(hyprctl -j monitors all)"
internal="$(jq -r '.[] | select(.name | test("^(eDP|LVDS|DSI)-")) | .name' <<<"${monitors}" | head -n 1)"
external="$(jq -r '[.[] | select(.disabled == false) | select(.name | test("^(eDP|LVDS|DSI)-") | not)] | (map(select(.focused == true)) + .) | .[0].name // empty' <<<"${monitors}")"

# Fail safe: never disable the panel unless Hyprland has an active external output.
[[ -n "${internal}" && -n "${external}" ]] || exit 0

workspaces="$(hyprctl -j workspaces)"
target_workspace="$(jq -r '[.[] | select(.focused == true)] | .[0].activeWorkspace.id // 0' <<<"${monitors}")"
mapfile -t occupied_workspaces < <(jq -r --arg monitor "${internal}" '.[] | select(.monitor == $monitor and .windows > 0) | .id' <<<"${workspaces}")

omarchy-hyprland-monitor-internal off

# A config reload returns before every compositor/output transition has settled.
internal_disabled=false
for _ in {1..30}; do
  if hyprctl -j monitors all | jq -e --arg monitor "${internal}" '.[] | select(.name == $monitor and .disabled == true)' >/dev/null; then
    internal_disabled=true
    break
  fi
  sleep 0.1
done
[[ "${internal_disabled}" == true ]] || exit 1

# Track automatic clamshell disable separately from the manual Omarchy toggle.
for state in /proc/acpi/button/lid/*/state; do
  if [[ -r "${state}" && $(<"${state}") == *closed* ]]; then
    printf 'closed\n' >"${XDG_RUNTIME_DIR:-/tmp}/omarchy-lid-clamshell"
    break
  fi
done

# Hyprland normally migrates these automatically. Repair only missing moves.
for workspace in "${occupied_workspaces[@]}"; do
  current_monitor="$(hyprctl -j workspaces | jq -r --argjson id "${workspace}" '.[] | select(.id == $id) | .monitor // empty')"
  if [[ "${current_monitor}" != "${external}" ]]; then
    hyprctl dispatch moveworkspacetomonitor "${workspace}" "${external}" >/dev/null
  fi
done

# Preserve whichever workspace was focused before the display transition.
if (( target_workspace > 0 )); then
  hyprctl dispatch focusmonitor "${external}" >/dev/null
  hyprctl dispatch workspace "${target_workspace}" >/dev/null
fi
