#!/usr/bin/env bash

set -euo pipefail

# Libinput may synthesize lid-open events after keyboard input to compensate for
# unreliable sensors. Trust the ACPI lid state before enabling the panel.
runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
clamshell_state="${runtime_dir}/omarchy-lid-clamshell"
handler_lock="${runtime_dir}/omarchy-lid-open.lock"
exec 8>"${handler_lock}"
flock -n 8 || exit 0

lid_is_open() {
  local found=false state

  for state in /proc/acpi/button/lid/*/state; do
    [[ -r "${state}" ]] || continue
    found=true
    [[ $(<"${state}") == *open* ]] || return 1
  done

  [[ "${found}" == true ]]
}

# Allow the kernel state to settle after the switch event.
sleep 0.5
if ! lid_is_open; then
  if omarchy-hw-external-monitors; then
    omarchy-lid-close-external
  else
    omarchy-hyprland-monitor-internal on
  fi
  exit 0
fi

# Serialize the final state check and enable action with the close handler.
action_lock="${runtime_dir}/omarchy-lid-display.lock"
exec 9>"${action_lock}"
flock -w 10 9 || exit 1

if lid_is_open; then
  omarchy-hyprland-monitor-internal on
  rm -f "${clamshell_state}"
elif omarchy-hw-external-monitors; then
  # The lid closed while this handler was waiting for the action lock.
  exec 9>&-
  omarchy-lid-close-external
else
  omarchy-hyprland-monitor-internal on
fi
