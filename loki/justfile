# Framework 13 (loki) setup & maintenance — run ON the laptop.
#
# Day-to-day updates go through Omarchy: `omarchy update` runs the post-update
# hook -> sync.sh automatically. This justfile only covers the dotfiles-repo
# operations Omarchy doesn't — its main use is `just sync` after editing dotfiles.
#
# Cold start (fresh box): install Omarchy, clone dotfiles, then `bash setup.sh`
# (just isn't installed until packages land, so the first run can't use it).

dotfiles := parent_directory(justfile_directory())

# List available recipes
default:
    @just --list

# --- provision -------------------------------------------------------------

# Fresh-provision this machine (cleanup, packages, dotfiles, services, config)
setup:
    bash {{justfile_directory()}}/setup.sh

# Re-assert customizations (stow, hypr overrides, pkg drops, mise) — run after editing dotfiles
sync:
    bash {{justfile_directory()}}/sync.sh

# Install/converge repo + AUR packages from the lists (after editing packages.repo/.aur)
packages:
    bash {{justfile_directory()}}/install/install-packages.sh

# Generate this machine's SSH keypairs (ed25519, per the naming convention)
ssh-keys:
    bash {{dotfiles}}/share/bin/ssh-keys-gen

# Download SSH keys + hosts.conf from the Proton Pass "SSH" vault into ~/.ssh
ssh-keys-fetch:
    #!/usr/bin/env bash
    set -euo pipefail
    command -v pass-cli >/dev/null 2>&1 || { echo "pass-cli not found — install proton-pass-cli-bin"; exit 1; }
    command -v jq >/dev/null 2>&1 || { echo "jq not found — install jq"; exit 1; }
    mkdir -p "${HOME}/.ssh/config.d"
    chmod 700 "${HOME}/.ssh" "${HOME}/.ssh/config.d"
    # "item title|destination dir" — SSH keys into ~/.ssh, hosts.conf into config.d
    for entry in \
      "hlx-admin|${HOME}/.ssh" \
      "homelab|${HOME}/.ssh" \
      "roomvibes|${HOME}/.ssh" \
      "rv-edgeplayer|${HOME}/.ssh" \
      "hosts.conf|${HOME}/.ssh/config.d"; do
      item="${entry%%|*}" dir="${entry##*|}"
      json="$(pass-cli item view --vault-name SSH --item-title "$item" --output json)" \
        || { echo "skip: '$item' not found in SSH vault"; continue; }
      # Read only attachment metadata; never print the item's secret fields.
      jq -r '.item as $i | .attachments[]? | [$i.share_id, $i.id, .id, .content.name] | @tsv' <<<"$json" \
        | while IFS=$'\t' read -r sid iid aid name; do
            out="$(pass-cli item attachment download --share-id "$sid" --item-id "$iid" --attachment-id "$aid" --output "$dir/$name" 2>&1)" \
              || { echo "FAILED: $dir/$name"; printf '%s\n' "$out" | sed 's/^/  /'; exit 1; }
            case "$name" in *.pub) chmod 644 "$dir/$name" ;; *) chmod 600 "$dir/$name" ;; esac
            echo "  $dir/$name"
          done
    done
    echo "done — SSH keys in ~/.ssh, hosts.conf in ~/.ssh/config.d (chmod 600)."

# Join the NetBird mesh with a setup key (enables+starts the service, then up)
netbird-up key="":
    #!/usr/bin/env bash
    set -euo pipefail
    command -v netbird >/dev/null 2>&1 || { echo "netbird not found — install it first"; exit 1; }
    key="{{key}}"
    if [ -z "$key" ]; then
      read -rs -p "NetBird setup key: " key < /dev/tty; echo
    fi
    sudo systemctl enable --now netbird
    netbird up --setup-key "$key"
    netbird status

# --- upgrades --------------------------------------------------------------

# Upgrade everything: Omarchy system update, then mise-managed dev tools
upgrade:
    omarchy update
    mise upgrade

# --- agents ----------------------------------------------------------------

# Playwright ships its own headless Chromium (~/.cache/ms-playwright), independent
# of the system chromium package. Mirrors kratos; other agents: share/mcp/README.md.
# Install Playwright MCP + headless Chromium so local agents can test web apps.
playwright-mcp:
    #!/usr/bin/env bash
    set -euo pipefail
    export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
    export PATH="$XDG_DATA_HOME/pnpm/bin:$PATH"   # so pnpm global bin resolves in this non-interactive shell
    echo "--- installing @playwright/mcp + playwright (pnpm global)"
    mise exec -- pnpm add -g @playwright/mcp playwright
    gbin="$(mise exec -- pnpm bin -g)"
    [ -n "$gbin" ] || { echo "could not resolve pnpm global bin dir"; exit 1; }
    echo "--- installing headless Chromium (Playwright-managed build)"
    "${gbin}/playwright" install chromium
    echo "--- registering 'playwright' MCP with Claude Code (user scope)"
    claude mcp remove playwright -s user >/dev/null 2>&1 || true
    claude mcp add playwright -s user -- "${gbin}/playwright-mcp" --headless --browser chromium --isolated
    echo
    echo "Done. Verify:  claude mcp list"
