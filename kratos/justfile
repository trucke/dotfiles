# Mac mini (kratos) setup & maintenance — run ON the mac mini.
#
# Cold start (fresh box):
#   /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
#   brew install just && just bootstrap
#
# Brewfile is the source of truth for everything brew-managed
# (CLIs, casks, infra, and the codex/claude/cursor/opencode/pi agents).
# Language runtimes + dev tools come from the shared mise config
# (../share/config/mise/config.toml, stowed to ~/.config/mise).
# t3 is the only non-brew agent (pnpm global).

brewfile := "Brewfile"
dotfiles := parent_directory(justfile_directory())

# Serial brew, both axes — the concurrent renderers garble the terminal with a
# "staircase" that stays broken after brew exits. Homebrew 5.x parallelizes BOTH
# downloads (DOWNLOAD_CONCURRENCY=auto) AND `brew bundle` installs (BUNDLE_JOBS=
# auto); pin both to 1 for clean, single-line output. Exported to every recipe.
export HOMEBREW_DOWNLOAD_CONCURRENCY := "1"
export HOMEBREW_BUNDLE_JOBS := "1"

# Pin pnpm's global bin dir to XDG on macOS too (else it defaults to ~/Library/
# pnpm): with XDG_DATA_HOME set, pnpm uses $XDG_DATA_HOME/pnpm/bin everywhere.
# Exported to every recipe shell, so the bootstrap (which never sources the zsh
# env) gets it too. Respects an already-set value.
export XDG_DATA_HOME := env_var_or_default("XDG_DATA_HOME", env_var("HOME") / ".local/share")

# List available recipes
default:
    @just --list

# --- provision -------------------------------------------------------------

# Full fresh-box provision: Homebrew + Brewfile + dotfiles + hardening + tools
bootstrap:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v brew >/dev/null 2>&1 && [ ! -x /opt/homebrew/bin/brew ]; then
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    eval "$(/opt/homebrew/bin/brew shellenv)"
    # Rosetta 2 (Apple Silicon only) — idempotent: skip if the runtime is already
    # present, otherwise softwareupdate re-runs the installer on every provision
    # and prints its benign "missing installKBytes" authoring warning each time.
    if [ "$(uname -m)" = "arm64" ] && [ ! -f /Library/Apple/usr/libexec/oah/libRosettaRuntime ]; then
      sudo softwareupdate --install-rosetta --agree-to-license || true
    fi
    just brew          # Brewfile first — installs stow + mise before they're used
    just stow          # stow now exists; also deploys the mise config
    just harden
    just mise          # needs the stowed mise config
    just repo-init     # migrate the bootstrap clone to colocated jj
    just pnpm-globals

# Provision packages/tools only: brew + mise + pnpm globals
setup: brew mise pnpm-globals

# Converge Homebrew to the Brewfile (additive; removes nothing).
# Trust the third-party taps wholesale — recent Homebrew refuses to load formulae
# from untrusted taps. Trusting the tap covers all its formulae (incl. deps like
# slp/krunkit's libkrun-efi + virglrenderer).
brew:
    #!/usr/bin/env bash
    set -euo pipefail
    for tap in infisical/get-cli netbirdio/tap anomalyco/tap; do
      brew tap "$tap" >/dev/null 2>&1 || true
      brew trust "$tap" || true          # POSITIONAL — there is NO `--tap` flag (that silently no-op'd)
    done
    brew bundle install --file {{brewfile}} --jobs 1   # serial installs (no staircase); env sets this too

# Install mise-managed runtimes/tools (config comes from the stowed share mise config)
mise:
    mise install

# Initialize the fresh Git bootstrap as a colocated jj repo and track main
repo-init:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{dotfiles}}"
    if ! mise exec -- jj root >/dev/null 2>&1; then
      mise exec -- jj git init --git-repo=. .
    fi
    if ! mise exec -- jj bookmark list --tracked main --remote origin 2>/dev/null | grep -q '^main:'; then
      mise exec -- jj bookmark track main --remote=origin
    fi

# Install pnpm global packages (t3 — the only non-brew agent)
pnpm-globals:
    #!/usr/bin/env bash
    set -euo pipefail
    # XDG_DATA_HOME is exported justfile-wide (pins pnpm's global bin to XDG). Just
    # prepend that bin dir so `pnpm add -g` finds it on PATH (this shell doesn't
    # source share/shell/path).
    export PATH="$XDG_DATA_HOME/pnpm/bin:$PATH"
    mise exec -- pnpm add -g t3

# Symlink shared dotfiles into place (zsh, ~/.config, ~/.local/bin, ~/.ssh) +
# deploy Agent Skills to ~/.agents/skills and bridge them into ~/.claude/skills
stow:
    mkdir -p "$HOME/Projects" "$HOME/.config/zed" "$HOME/.local/bin" "$HOME/.ssh" \
      "$HOME/.pi/agent/extensions" "$HOME/.pi/agent/skills" "$HOME/.pi/agent/themes"
    chmod 700 "$HOME/.ssh"
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME" zsh
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME/.config" config
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME/.local/bin" bin
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME/.ssh" ssh
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME/.pi/agent" pi
    DOTFILES="{{dotfiles}}" bash "{{dotfiles}}/share/bin/link-agent-skills"

# Apply macOS security hardening (headless-appropriate)
harden:
    bash {{justfile_directory()}}/harden.sh

# Generate this machine's SSH keypairs (ed25519, per the naming convention)
ssh-keys:
    bash {{dotfiles}}/share/bin/ssh-keys-gen

# Join the NetBird mesh headlessly with a setup key (no interactive SSO): installs +
# starts the service, then `netbird up --setup-key`. Get a reusable key from the
# NetBird admin console. Passing it as an arg lands in shell history — omit the arg
# to be prompted instead.

# Join the NetBird mesh with a setup key (installs+starts the service, then up)
netbird-up key="":
    #!/usr/bin/env bash
    set -euo pipefail
    key="{{key}}"
    if [ -z "$key" ]; then
      read -rs -p "NetBird setup key: " key < /dev/tty; echo
    fi
    sudo netbird service install || true   # idempotent: already-installed is fine
    sudo netbird service start   || true
    netbird up --setup-key "$key"
    netbird status

# Install the official Podman (its .pkg bundles the machine + VM provider; Podman
# does not recommend the Homebrew formula) + start its machine (one-time).
podman-init:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! /opt/podman/bin/podman --version >/dev/null 2>&1; then
      echo "Installing the official Podman .pkg..."
      pkg="$(mktemp -d)/podman.pkg"
      url="$(curl -fsSL https://api.github.com/repos/containers/podman/releases/latest | grep -m1 -oE '"browser_download_url": "[^"]+podman-installer-macos-arm64\.pkg"' | cut -d'"' -f4)"
      [ -n "$url" ] || { echo "Could not resolve the Podman installer URL"; exit 1; }
      curl -fsSL -o "$pkg" "$url"
      sudo installer -pkg "$pkg" -target /
    fi
    export PATH="/opt/podman/bin:$PATH"
    podman machine init || true
    sudo podman-mac-helper install    # before start, so the machine wires /var/run/docker.sock
    podman machine start
    echo "--- verifying: podman run --rm quay.io/podman/hello"
    podman run --rm quay.io/podman/hello

# Start Syncthing as a login service (folder sync between the machines + NAS).
# Fresh box: approve the macOS folder-access (TCC) prompts from a GUI session —
# the headless service hangs on them until approved.
syncthing-setup:
    brew services start syncthing
    @echo "Syncthing running. Fresh box: approve the folder-access prompts via a GUI session once."

# Point Time Machine at the NAS over SMB (one-time). Prompts for the password;
# it's stored in the system keychain (daemon-readable, so it works headless) and
# never touches this repo. Use a URL-safe password (no @ / : in it).
timemachine share="smb://tm@truenas.local/timemachine":
    #!/usr/bin/env bash
    set -euo pipefail
    read -rs -p "SMB password for {{share}}: " pw < /dev/tty; echo
    url="{{share}}"
    sudo tmutil setdestination -a "${url/@/:${pw}@}"
    sudo tmutil enable
    tmutil destinationinfo
    echo "Destination set + backups enabled. Start the first backup with:"
    echo "  tmutil startbackup --auto --block"

# macOS keeps the login keychain LOCKED with no GUI login, so Keychain-backed CLIs
# (Proton Pass CLI, etc.) fail over SSH with "User interaction is not allowed".
# This unlocks it + disables auto-lock (until reboot). Prompts for the login
# password via /dev/tty; never stored, never on the command line.

# Unlock the login keychain so Keychain CLIs (Proton Pass CLI, etc.) work over SSH
unlock-keychain:
    #!/usr/bin/env bash
    set -euo pipefail
    kc="${HOME}/Library/Keychains/login.keychain-db"   # explicit path (verified working)
    read -rs -p "Login password for $(id -un): " pw < /dev/tty; echo
    security unlock-keychain -p "$pw" "$kc"
    security set-keychain-settings "$kc"   # no auto-lock, no lock-on-sleep
    unset pw
    echo "login keychain unlocked + auto-lock disabled (re-run after a reboot)."

# Authenticate pass-cli (Proton Pass CLI) with a Personal Access Token. Create the
# PAT in the Proton Pass web app (format pst_<token>::<key>). Prompts for it — never
# on the command line. Prereqs: pass-cli installed + `just unlock-keychain` first
# (the session is stored in the login keychain).

# Log pass-cli in with a Personal Access Token (prompted)
pass-login:
    #!/usr/bin/env bash
    set -euo pipefail
    command -v pass-cli >/dev/null 2>&1 || { echo "pass-cli not found — brew install proton-pass-cli"; exit 1; }
    read -rs -p "Proton Pass PAT (pst_...::...): " pat < /dev/tty; echo
    [ -n "$pat" ] || { echo "no token entered"; exit 1; }
    pass-cli login --pat "$pat"
    unset pat
    pass-cli info

# Fetch the SSH key + hosts.conf attachments from the Proton Pass "SSH" vault into
# ~/.ssh (keys) and ~/.ssh/config.d (hosts.conf). Only attachment metadata (ids +
# filenames) is read via jq — the item's secret fields are never printed. Prereqs:
# `just pass-login` done + `just unlock-keychain`.

# Download SSH keys + hosts.conf from the Proton Pass "SSH" vault into ~/.ssh
ssh-keys-fetch:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p "${HOME}/.ssh/config.d"
    chmod 700 "${HOME}/.ssh" "${HOME}/.ssh/config.d"
    # "item title|destination dir" — SSH keys into ~/.ssh, hosts.conf into config.d
    for entry in \
      "hlx-admin|${HOME}/.ssh" \
      "homelab|${HOME}/.ssh" \
      "roomvibes|${HOME}/.ssh" \
      "rv-edgeplayer|${HOME}/.ssh" \
      "hosts.conf|${HOME}/.ssh/config.d"; do
      item="${entry%%|*}" dir="${entry##*|}"
      json="$(pass-cli item view --vault-name SSH --item-title "$item" --output json)" \
        || { echo "skip: '$item' not found in SSH vault"; continue; }
      # one jq pass emits share_id, item_id, attachment_id, filename per attachment;
      # nothing else from the item (its secret fields) is ever read.
      jq -r '.item as $i | .attachments[]? | [$i.share_id, $i.id, .id, .content.name] | @tsv' <<<"$json" \
        | while IFS=$'\t' read -r sid iid aid name; do
            out="$(pass-cli item attachment download --share-id "$sid" --item-id "$iid" --attachment-id "$aid" --output "$dir/$name" 2>&1)" \
              || { echo "FAILED: $dir/$name"; printf '%s\n' "$out" | sed 's/^/  /'; exit 1; }
            case "$name" in *.pub) chmod 644 "$dir/$name" ;; *) chmod 600 "$dir/$name" ;; esac
            echo "  $dir/$name"
          done
    done
    echo "done — SSH keys in ~/.ssh, hosts.conf in ~/.ssh/config.d (chmod 600)."

# Install + start the t3 serve LaunchDaemon: runs `t3 serve` persistently, bound
# to the NetBird IP, with auto-restart + start-on-boot. Needs netbird up + t3.
t3-serve-install:
    #!/usr/bin/env bash
    set -euo pipefail
    label="com.t3code.serve"
    plist="/Library/LaunchDaemons/${label}.plist"
    sed -e "s|__HOME__|${HOME}|g" -e "s|__USER__|$(id -un)|g" "{{justfile_directory()}}/services/${label}.plist" | sudo tee "$plist" >/dev/null
    sudo chown root:wheel "$plist" && sudo chmod 644 "$plist"
    sudo launchctl bootout system "$plist" 2>/dev/null || true
    sudo launchctl bootstrap system "$plist"
    echo "Installed. Logs: ${HOME}/Library/Logs/t3-serve.log ; status: sudo launchctl print system/${label}"
    # print a ready-to-use pairing token/URL (no restart needed)
    {{just_executable()}} --justfile "{{justfile()}}" t3-pair

# Stop + remove the t3 serve LaunchDaemon
t3-serve-uninstall:
    -sudo launchctl bootout system /Library/LaunchDaemons/com.t3code.serve.plist
    sudo rm -f /Library/LaunchDaemons/com.t3code.serve.plist
    @echo "t3 serve daemon removed."

# `t3 auth pairing create` writes to the running server's auth control plane, so
# the live t3 serve honors the token with NO daemon restart. Pair the loki client
# with the printed pairUrl. Default TTL 15m — override e.g. `just t3-pair 1h`.

# Mint a fresh client pairing token + URL on demand (no daemon restart)
t3-pair ttl="15m":
    #!/usr/bin/env bash
    set -euo pipefail
    export PATH="${XDG_DATA_HOME}/pnpm/bin:${PATH}"   # find the pnpm-global t3
    t3 auth pairing create --ttl "{{ttl}}" --base-url http://kratos.netbird.cloud:3773 --log-level warn

# Restart the t3 serve daemon (rarely needed). For a pairing token, use t3-pair.
t3-serve-restart:
    sudo launchctl kickstart -k system/com.t3code.serve
    @echo "t3 serve restarted. Mint a pairing token with: just t3-pair"

# Install/refresh Herdr integrations for the coding agents managed on this host
herdr-integrations:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p "$HOME/.pi/agent/extensions" "$HOME/.claude" "$HOME/.codex" \
      "$HOME/.config/opencode" "$HOME/.cursor"
    for integration in pi claude codex opencode cursor; do
      echo "--- herdr integration: $integration"
      herdr integration install "$integration"
    done
    herdr integration status

# Gives agents a headless browser to drive/verify the web apps they build, with
# no display attached. `claude --chrome` and computer-use both need a monitor and
# won't run on this box; a Playwright MCP server is the headless path. Registers
# with Claude Code; other agents: share/mcp/README.md.

# Install Playwright MCP + headless Chromium and register it with Claude Code
playwright-mcp:
    #!/usr/bin/env bash
    set -euo pipefail
    # XDG_DATA_HOME is exported justfile-wide; prepend pnpm's XDG bin dir so
    # `add -g` finds it on PATH, after which `pnpm bin -g` resolves reliably.
    export PATH="$XDG_DATA_HOME/pnpm/bin:$PATH"
    echo "--- installing @playwright/mcp + playwright (pnpm global)"
    mise exec -- pnpm add -g @playwright/mcp playwright
    gbin="$(mise exec -- pnpm bin -g)"
    [ -n "$gbin" ] || { echo "could not resolve pnpm global bin dir"; exit 1; }
    echo "--- installing headless Chromium (Playwright-managed build)"
    "${gbin}/playwright" install chromium
    echo "--- registering 'playwright' MCP with Claude Code (user scope)"
    claude mcp remove playwright -s user >/dev/null 2>&1 || true
    claude mcp add playwright -s user -- "${gbin}/playwright-mcp" --headless --browser chromium --isolated
    echo
    echo "Done. Verify:  claude mcp list"
    echo "Agents drive a served app at http://localhost:<port>, assert the DOM,"
    echo "and screenshot — no display needed. Other agents: share/mcp/README.md"

# --- upgrades --------------------------------------------------------------

# Upgrade everything (packages only; does NOT touch macOS — see upgrade-macos)
upgrade: upgrade-brew upgrade-mise upgrade-t3

# Upgrade all Homebrew packages (formulae + casks; --greedy bumps self-updaters)
upgrade-brew:
    brew update
    brew upgrade
    brew upgrade --cask --greedy

# Upgrade all mise-managed tools
upgrade-mise:
    mise upgrade

# Update the T3 CLI (pnpm global)
upgrade-t3:
    pnpm add -g t3@latest

# Update the coding agents only (brew agents + t3)
upgrade-agents: upgrade-t3
    brew upgrade --cask --greedy codex claude-code@latest cursor-cli
    brew upgrade pi-coding-agent anomalyco/tap/opencode

# Upgrade macOS system software (point releases + security). RESTARTS the box;
# it returns on its own (pmset autorestart). Major jumps: upgrade-macos-major.
[confirm("Install all macOS updates and restart the Mac mini? SSH drops; the box returns on its own.")]
upgrade-macos:
    softwareupdate --list
    sudo softwareupdate --install --all --restart

# List available full macOS installers (valid versions for upgrade-macos-major)
upgrade-macos-list:
    softwareupdate --list-full-installers

# Run upgrade-macos-list first for valid versions. Downloads the full installer,
# then startosinstall installs + restarts (returns on its own via pmset autorestart).
# Upgrade to a MAJOR macOS version, e.g.: just upgrade-macos-major 15.5
[confirm("Download + install a MAJOR macOS upgrade, then restart? SSH drops; the box returns on its own.")]
upgrade-macos-major version:
    #!/usr/bin/env bash
    set -euo pipefail
    softwareupdate --fetch-full-installer --full-installer-version {{version}}
    apps=("/Applications/Install macOS"*.app)
    [ -e "${apps[0]}" ] || { echo "No 'Install macOS…' app found — run upgrade-macos-list first" >&2; exit 1; }
    installer="${apps[0]}"
    sudo "$installer/Contents/Resources/startosinstall" --agreetolicense --nointeraction

# --- maintenance -----------------------------------------------------------

# Show current brew / mise state
audit:
    @echo "== brew leaves ==" && brew leaves --installed-on-request | sort
    @echo "== casks =="       && brew list --cask | sort
    @echo "== services =="    && brew services list
    @echo "== mise =="        && mise ls

# Dry-run: list what cleanup would remove (removes nothing)
cleanup-preview:
    @echo ">> DRY RUN — nothing removed. Items below are NOT in {{brewfile}}."
    brew bundle cleanup --file {{brewfile}}

# Destructive: uninstall everything not in the Brewfile (formulae/casks; no zap)
[confirm("Uninstall everything not in the Brewfile? Run cleanup-preview first.")]
cleanup-apply:
    brew bundle dump --file ~/Brewfile.before-cleanup.$(date +%Y%m%d%H%M%S) --force
    brew bundle cleanup --file {{brewfile}} --force

# Destructive: uninstall + zap casks (DELETES app data). e.g. just zap obsidian signal
[confirm("zap DELETES application data for the given casks. Proceed?")]
zap +casks:
    for c in {{casks}}; do echo ">> zapping $c" && brew uninstall --cask --zap "$c" || true; done

# Safe cache prune
cache-safe:
    brew cleanup
    pnpm store prune || true

# Destructive: caches that re-download on next use
[confirm("Delete ~/.cache/{bun,deno,pnpm}? They re-download on next use.")]
cache-redownload:
    rm -rf ~/.cache/bun ~/.cache/deno ~/.cache/pnpm
