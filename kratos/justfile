# Mac mini (kratos) setup & maintenance — run ON the mac mini.
#
# Cold start (fresh box):
#   /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
#   brew install just && just bootstrap
#
# Brewfile is the source of truth for everything brew-managed
# (CLIs, casks, infra, and the codex/claude/cursor/opencode/pi agents).
# Language runtimes + dev tools come from the shared mise config
# (../share/config/mise/config.toml, stowed to ~/.config/mise).
# t3 is the only non-brew agent (pnpm global).

brewfile := "Brewfile"
dotfiles := parent_directory(justfile_directory())

# List available recipes
default:
    @just --list

# --- provision -------------------------------------------------------------

# Full fresh-box provision: Homebrew + Brewfile + dotfiles + hardening + tools
bootstrap:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v brew >/dev/null 2>&1 && [ ! -x /opt/homebrew/bin/brew ]; then
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    eval "$(/opt/homebrew/bin/brew shellenv)"
    sudo softwareupdate --install-rosetta --agree-to-license || true
    just brew          # Brewfile first — installs stow + mise before they're used
    just stow          # stow now exists; also deploys the mise config
    just harden
    just mise          # needs the stowed mise config
    just pnpm-globals

# Provision packages/tools only: brew + mise + pnpm globals
setup: brew mise pnpm-globals

# Converge Homebrew to the Brewfile (additive; removes nothing).
# Trust the third-party taps wholesale — recent Homebrew refuses to load formulae
# from untrusted taps. Trusting the tap covers all its formulae (incl. deps like
# slp/krunkit's libkrun-efi + virglrenderer).
brew:
    #!/usr/bin/env bash
    set -euo pipefail
    for tap in infisical/get-cli netbirdio/tap anomalyco/tap; do
      brew tap "$tap" >/dev/null 2>&1 || true
      brew trust --tap "$tap" || true
    done
    brew bundle install --file {{brewfile}}

# Install mise-managed runtimes/tools (config comes from the stowed share mise config)
mise:
    mise install

# Install pnpm global packages (t3 — the only non-brew agent)
# `mise exec` so pnpm resolves even before mise shims are on PATH (fresh box).
pnpm-globals:
    mise exec -- pnpm add -g t3

# Symlink shared dotfiles into place (zsh, ~/.config, ~/.local/bin, ~/.ssh)
stow:
    mkdir -p "$HOME/.config/zed" "$HOME/.local/bin" "$HOME/.ssh" \
      "$HOME/.pi/agent/extensions" "$HOME/.pi/agent/skills" "$HOME/.pi/agent/themes"
    chmod 700 "$HOME/.ssh"
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME" zsh
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME/.config" config
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME/.local/bin" bin
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME/.ssh" ssh
    stow --restow --dir="{{dotfiles}}/share" --target="$HOME/.pi/agent" pi

# Apply macOS security hardening (headless-appropriate)
harden:
    bash {{justfile_directory()}}/harden.sh

# Generate this machine's SSH keypairs (ed25519, per the naming convention)
ssh-keys:
    bash {{dotfiles}}/share/bin/ssh-keys-gen

# Install the official Podman (its .pkg bundles the machine + VM provider; Podman
# does not recommend the Homebrew formula) + start its machine (one-time).
podman-init:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! /opt/podman/bin/podman --version >/dev/null 2>&1; then
      echo "Installing the official Podman .pkg..."
      pkg="$(mktemp -d)/podman.pkg"
      url="$(curl -fsSL https://api.github.com/repos/containers/podman/releases/latest | grep -oE '"browser_download_url": "[^"]+podman-installer-macos-arm64\.pkg"' | head -1 | cut -d'"' -f4)"
      [ -n "$url" ] || { echo "Could not resolve the Podman installer URL"; exit 1; }
      curl -fsSL -o "$pkg" "$url"
      sudo installer -pkg "$pkg" -target /
    fi
    export PATH="/opt/podman/bin:$PATH"
    podman machine init || true
    sudo podman-mac-helper install    # before start, so the machine wires /var/run/docker.sock
    podman machine start

# Point Time Machine at the NAS over SMB (one-time). Prompts for the password;
# it's stored in the system keychain (daemon-readable, so it works headless) and
# never touches this repo. Use a URL-safe password (no @ / : in it).
timemachine share="smb://tm@truenas.local/timemachine":
    #!/usr/bin/env bash
    set -euo pipefail
    read -rs -p "SMB password for {{share}}: " pw < /dev/tty; echo
    url="{{share}}"
    sudo tmutil setdestination -a "${url/@/:${pw}@}"
    sudo tmutil enable
    tmutil destinationinfo
    echo "Destination set + backups enabled. Start the first backup with:"
    echo "  tmutil startbackup --auto --block"

# --- upgrades --------------------------------------------------------------

# Upgrade everything (packages only; does NOT touch macOS — see upgrade-macos)
upgrade: upgrade-brew upgrade-mise upgrade-t3

# Upgrade all Homebrew packages (formulae + casks; --greedy bumps self-updaters)
upgrade-brew:
    brew update
    brew upgrade
    brew upgrade --cask --greedy

# Upgrade all mise-managed tools
upgrade-mise:
    mise upgrade

# Update the T3 CLI (pnpm global)
upgrade-t3:
    pnpm add -g t3@latest

# Update the coding agents only (brew agents + t3)
upgrade-agents: upgrade-t3
    brew upgrade --cask --greedy codex claude-code@latest cursor-cli
    brew upgrade pi-coding-agent anomalyco/tap/opencode

# Keeps FileVault ON: does an AUTHENTICATED restart so the headless box unlocks
# and returns on its own. Prompts once for your admin password (used for both
# sudo and the FileVault unlock). Major jumps: upgrade-macos-major.
# Upgrade macOS system software (point releases + security). RESTARTS the box.
[confirm("Install all macOS updates and authenticated-restart the Mac mini? SSH drops; the box returns on its own.")]
upgrade-macos:
    #!/usr/bin/env bash
    set -euo pipefail
    softwareupdate --list
    read -rs -p "Admin password (sudo + FileVault authenticated restart): " pw < /dev/tty; echo
    printf '%s\n' "$pw" | sudo -S -v
    printf '%s' "$pw" | sudo softwareupdate --install --all --restart --user "$(id -un)" --stdinpass

# List available full macOS installers (valid versions for upgrade-macos-major)
upgrade-macos-list:
    softwareupdate --list-full-installers

# Run upgrade-macos-list first for valid versions. Downloads the full installer,
# then startosinstall does an AUTHENTICATED restart (FileVault-safe, headless).
# Prompts once for your admin password (sudo + FileVault unlock).
# Upgrade to a MAJOR macOS version, e.g.: just upgrade-macos-major 15.5
[confirm("Download + install a MAJOR macOS upgrade, then authenticated-restart? SSH drops; the box returns on its own.")]
upgrade-macos-major version:
    #!/usr/bin/env bash
    set -euo pipefail
    softwareupdate --fetch-full-installer --full-installer-version {{version}}
    installer="$(ls -d "/Applications/Install macOS"*.app | head -n1)"
    read -rs -p "Admin password (sudo + FileVault authenticated restart): " pw < /dev/tty; echo
    printf '%s\n' "$pw" | sudo -S -v
    printf '%s' "$pw" | sudo "$installer/Contents/Resources/startosinstall" --agreetolicense --nointeraction --user "$(id -un)" --stdinpass

# --- maintenance -----------------------------------------------------------

# Show current brew / mise state
audit:
    @echo "== brew leaves ==" && brew leaves --installed-on-request | sort
    @echo "== casks =="       && brew list --cask | sort
    @echo "== services =="    && brew services list
    @echo "== mise =="        && mise ls

# Dry-run: list what cleanup would remove (removes nothing)
cleanup-preview:
    @echo ">> DRY RUN — nothing removed. Items below are NOT in {{brewfile}}."
    brew bundle cleanup --file {{brewfile}}

# Destructive: uninstall everything not in the Brewfile (formulae/casks; no zap)
[confirm("Uninstall everything not in the Brewfile? Run cleanup-preview first.")]
cleanup-apply:
    brew bundle dump --file ~/Brewfile.before-cleanup.$(date +%Y%m%d%H%M%S) --force
    brew bundle cleanup --file {{brewfile}} --force

# Destructive: uninstall + zap casks (DELETES app data). e.g. just zap obsidian signal
[confirm("zap DELETES application data for the given casks. Proceed?")]
zap +casks:
    for c in {{casks}}; do echo ">> zapping $c" && brew uninstall --cask --zap "$c" || true; done

# Safe cache prune
cache-safe:
    brew cleanup
    pnpm store prune || true

# Destructive: caches that re-download on next use
[confirm("Delete ~/.cache/{bun,deno,pnpm}? They re-download on next use.")]
cache-redownload:
    rm -rf ~/.cache/bun ~/.cache/deno ~/.cache/pnpm
